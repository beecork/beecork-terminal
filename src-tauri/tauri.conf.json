{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Beecork Terminal",
  "version": "0.1.0",
  "identifier": "com.beecork.terminal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Beecork Terminal",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/beecork/beecork-terminal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGRDZERkI2N0E1RUYyRTYKUldUbThsNTZ0dC9XTDJZMGdQWjZhVXNjVHhFZGlhaWJJTmF5WGNoZmNtbUszeGJ4ZTR0OXE0TFYK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Beecork",
    "category": "DeveloperTool",
    "copyright": "© Beecork",
    "shortDescription": "A terminal-first cockpit for CLI coding agents.",
    "longDescription": "Beecork Terminal is a desktop cockpit for CLI coding agents (Claude Code, Codex, any CLI): a full terminal, a live git-aware diff view, and a file browser/editor side by side.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
